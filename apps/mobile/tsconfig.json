{
    "extends": "@repo/typescript-config/react-native",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts",
        "nativewind-env.d.ts",
        "./types/images.d.ts"
    ],
    "exclude": ["node_modules", "babel.config.js", "metro.config.js", "jest.config.js"]
}
